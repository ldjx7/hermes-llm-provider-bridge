# Optional. Protects /admin/* endpoints.
BRIDGE_ADMIN_TOKEN=

# Optional. Protects /v1/* provider endpoints. Leave empty to accept no key or any caller-supplied key.
BRIDGE_API_KEY=

# Optional. Overrides config file path.
BRIDGE_CONFIG=./bridge.config.json

# Optional. Overrides configured host and port.
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=18777

# Optional. Used by compose.yml when mounting Claude Code config.
# CLAUDE_CONFIG_DIR=/absolute/path/to/.claude
